PORT=3000
BASE_URL=https://your-public-url

# PostgreSQL — set to use persistent storage (required on Render)
DATABASE_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=coral

# ElevenLabs (unused with Realtime API, kept for fallback)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Provider selection (unused with Realtime API, kept for fallback)
TTS_PROVIDER=elevenlabs
STT_PROVIDER=openai

# Call Recording
RECORDING_ENABLED=true
RECORDING_CHANNELS=2

# AudioSocket (Asterisk / VICIdial integration)
AUDIOSOCKET_ENABLED=true
AUDIOSOCKET_PORT=9092
AUDIOSOCKET_HOST=0.0.0.0

# ── Platform security (new) ─────────────────────────────────────────
# Set ADMIN_PASSWORD to require login on the dashboard and all /api routes.
# A bootstrap 'admin' user is created/rotated from this value at startup.
ADMIN_PASSWORD=

# Set to "true" to reject Twilio webhooks without a valid X-Twilio-Signature.
# Requires BASE_URL to exactly match the public URL Twilio calls.
TWILIO_VALIDATE_SIGNATURE=false

# Shared secret for lead-ingestion webhooks (/webhook/weblead, /webhooks/jangl).
# When set, requests must include x-webhook-secret, ?secret=, or an
# x-webhook-signature HMAC-SHA256 of the JSON body.
WEBLEAD_SHARED_SECRET=

# Debug
DEBUG=true
